generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  passwordHash      String             @map("password_hash")
  role              UserRole
  isActive          Boolean            @default(true) @map("is_active")
  lastSeenAt        DateTime?          @map("last_seen_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  biometricConsents BiometricConsent[]
  bookings          Booking[]
  focusScores       FocusScore[]
  orders            MarketplaceOrder[]
  metrics           Metric[]
  professional      Professional?
  ownedTokens       TimeToken[]        @relation("TokenOwner")
}

model Professional {
  id                 String                         @id @default(uuid())
  userId             String                         @unique @map("user_id")
  baseRate           Decimal                        @map("base_rate")
  currency           String                         @default("INR")
  status             ProfessionalStatus
  fullName           String?                        @map("full_name")
  bio                String?
  availabilitySummary String?                        @map("availability_summary")
  createdAt          DateTime                       @default(now()) @map("created_at")
  certifications     String[]                       @default([])
  skills             String[]                       @default([])
  verificationStatus ProfessionalVerificationStatus @default(unverified) @map("verification_status")
  availabilitySlots  AvailabilitySlot[]
  user               User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions           Session[]
  tokens             TimeToken[]
  weeklyAvailability WeeklyAvailability[]
}

model Metric {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  metricType   String   @map("metric_type")
  value        Decimal
  recordedAt   DateTime @map("recorded_at")
  createdAt    DateTime @default(now()) @map("created_at")
  confidence   Decimal?
  sourceDevice String?  @map("source_device")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
}

model BiometricConsent {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  metricType String    @map("metric_type")
  source     String
  grantedAt  DateTime  @default(now()) @map("granted_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, metricType, source])
}

model FocusScore {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  score        Decimal
  modelVersion String   @map("model_version")
  computedAt   DateTime @default(now()) @map("computed_at")
  breakdown    Json?
  confidence   Decimal?
  validFrom    DateTime @default(now()) @map("valid_from")
  validUntil   DateTime @default(now()) @map("valid_until")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TimeToken {
  id              String            @id @default(uuid())
  professionalId  String            @map("professional_id")
  ownerId         String?           @map("owner_id")
  durationMinutes Int               @map("duration_minutes")
  price           Decimal
  currency        String            @default("INR")
  state           TokenState
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  description     String?
  expertiseTags   String[]          @default([])
  title           String            @default("Session")
  topics          String[]          @default([])
  booking         Booking?
  order           MarketplaceOrder?
  owner           User?             @relation("TokenOwner", fields: [ownerId], references: [id])
  professional    Professional      @relation(fields: [professionalId], references: [id])

  @@index([state])
}

model WeeklyAvailability {
  id             String       @id @default(uuid())
  professionalId String       @map("professional_id")
  dayOfWeek      Int          @map("day_of_week")
  startMinute    Int          @map("start_minute")
  endMinute      Int          @map("end_minute")
  timezone       String       @default("UTC")
  createdAt      DateTime     @default(now()) @map("created_at")
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, dayOfWeek])
}

model AvailabilitySlot {
  id             String                 @id @default(uuid())
  professionalId String                 @map("professional_id")
  startAt        DateTime               @map("start_at")
  endAt          DateTime               @map("end_at")
  status         AvailabilitySlotStatus @default(available)
  createdAt      DateTime               @default(now()) @map("created_at")
  professional   Professional           @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, startAt])
}

model MarketplaceOrder {
  id        String    @id @default(uuid())
  tokenId   String    @unique @map("token_id")
  buyerId   String    @map("buyer_id")
  pricePaid Decimal   @map("price_paid")
  currency  String    @default("INR")
  createdAt DateTime  @default(now()) @map("created_at")
  buyer     User      @relation(fields: [buyerId], references: [id])
  token     TimeToken @relation(fields: [tokenId], references: [id])
}

model Booking {
  id          String        @id @default(uuid())
  tokenId     String        @unique @map("token_id")
  buyerId     String        @map("buyer_id")
  scheduledAt DateTime?     @map("scheduled_at")
  status      BookingStatus
  meetingLink String?       @map("meeting_link")
  createdAt   DateTime      @default(now()) @map("created_at")
  metadata    Json?
  buyer       User          @relation(fields: [buyerId], references: [id])
  token       TimeToken     @relation(fields: [tokenId], references: [id])
  session     Session?
}

model Session {
  id             String        @id @default(uuid())
  bookingId      String        @unique @map("booking_id")
  professionalId String        @map("professional_id")
  startedAt      DateTime?     @map("started_at")
  endedAt        DateTime?     @map("ended_at")
  buyerJoinedAt  DateTime?     @map("buyer_joined_at")
  status         SessionStatus
  provider       SessionProvider @default(jitsi)
  recordingUrl   String?       @map("recording_url")
  createdAt      DateTime      @default(now()) @map("created_at")
  payment        Payment?
  booking        Booking       @relation(fields: [bookingId], references: [id])
  professional   Professional  @relation(fields: [professionalId], references: [id])
}

enum SessionProvider {
  jitsi
  webrtc
}

model Payment {
  id            String        @id @default(uuid())
  sessionId     String        @unique @map("session_id")
  amount        Decimal
  currency      String        @default("INR")
  erpInvoiceRef String?       @map("erp_invoice_ref")
  status        PaymentStatus
  settledAt     DateTime?     @map("settled_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  session       Session       @relation(fields: [sessionId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  eventType  String   @map("event_type")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
}

enum UserRole {
  buyer
  professional
  admin
  bio_engine
}

enum ProfessionalStatus {
  active
  suspended
}

enum ProfessionalVerificationStatus {
  unverified
  pending
  verified
  rejected
}

enum TokenState {
  drafted
  listed
  purchased
  consumed
  cancelled
}

enum BookingStatus {
  pending_schedule
  scheduled
  completed
  cancelled
}

enum SessionStatus {
  pending
  active
  completed
  failed
  missed
  cancelled_by_buyer
  cancelled_by_professional
  refund_requested
  refunded
}

enum PaymentStatus {
  pending
  settled
  failed
  refund_requested
  refunded
  pending_review
  disputed
}

enum AvailabilitySlotStatus {
  available
  blocked
}
